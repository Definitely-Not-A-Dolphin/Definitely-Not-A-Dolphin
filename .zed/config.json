// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "auto_update": true,
  "base_keymap": "VSCode",
  "bottom_dock_layout": "contained",
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 14,
  "buffer_font_weight": null,
  "calls": {
    "mute_on_join": true,
  },
  "completions": {
    "lsp": true,
  },
  "cursor_shape": "bar",
  "disable_ai": true,
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": false,
    },
  },
  "format_on_save": "off",
  "icon_theme": "Colored Zed Icons Theme Dark",
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "indent_aware",
  },
  "gutter": {
    "breakpoints": true,
    "folds": true,
    "line_numbers": true,
    "min_line_number_digits": 4,
    "runnables": true,
  },
  "languages": {
    "C++": {
      "formatter": "auto",
    },
    "EJS": {
      "formatter": "language_server",
    },
    "HTML": {
      "language_servers": ["auto"],
    },
    "JavaScript": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
      ],
      "formatter": "language_server",
    },
    "Markdown": {
      "format_on_save": "off",
    },
    "Python": {
      "tab_size": 2,
      "formatter": "language_server",
    },
    "Rust": {
      "tab_size": 2,
      //"formatter": "language_server"
    },
    "Shell Script": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "shfmt",
        },
      },
    },
    "Svelte": {
      "formatter": "auto",
    },
    "TSX": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
      ],
      "formatter": "language_server",
    },
    "TypeScript": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
      ],
      "formatter": "language_server",
    },
    "Typst": {
      "soft_wrap": "editor_width",
    },
  },
  "lsp": {
    "discord_presence": {
      "initialization_options": {
        "application_id": "1263505205522337886",
        "base_icons_url": "https://raw.githubusercontent.com/xhyrom/zed-discord-presence/main/assets/icons/",
        "state": "Working on {filename}",
        "details": "In {workspace}",
        "large_image": "{base_icons_url}/{language:lo}.png",
        "large_text": "{language:u}",
        "small_image": "{base_icons_url}/zed.png",
        "small_text": "Zed",
        "idle": {
          "timeout": 300,
          "action": "change_activity",

          "state": "Idling",
          "details": "Idling is a lie; I am just spreading my productivity",
          "large_image": "{base_icons_url}/zed.png",
          "large_text": "Zed",
          "small_image": "{base_icons_url}/idle.png",
          "small_text": "Idle",
        },
        "git_integration": true,
        "languages": {
          "python": {
            "details": "I am being forced to write python help me pls",
          },
          "rust": {
            "state": "Rusting on {filename}",
            "details": "Rustacean at work",
          },
          "typescript": {
            "state": "Typing on {filename}",
            "details": "Typing my script",
          },
        },
      },
    },
    "deno": {
      "settings": {
        "deno": {
          "enable": true,
        },
      },
    },
    "tinymist": {
      "settings": {
        "outputPath": "$root/output/$name",
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
  },
  "middle_click_paste": true,
  "minimap": {
    "show": "auto",
    "thumb": "always",
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false,
  },
  "tabs": {
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true,
    "show_close_button": null,
  },
  "tab_size": 2,
  "terminal": {
    "line_height": "comfortable",
  },
  "theme": {
    "mode": "dark",
    "light": "Tokyo Night Light",
    "dark": "GitHub Dark Default",
    // Other good ones
    // - Github Dark Default
    // - Tokyo Night
    // - Tokyo Night Moon
    // - Tokyo Night Storm
  },
  "ui_font_size": 16,
  "vim_mode": false,
}
